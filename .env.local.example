# Local development environment — copy to .env.local
# Run `pnpm local:start` first to get the values below from `supabase status`

# Local Supabase PostgreSQL (port 54322)
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres"

# Local Supabase API (port 54321)
# Copy keys from the `pnpm local:start` output:
#   "Publishable" key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   "Secret" key      → SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<Publishable key from local:start output>"
SUPABASE_SERVICE_ROLE_KEY="<Secret key from local:start output>"

# JWT secret for local dev (any string works)
JWT_SECRET="local-dev-secret-change-in-production"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
